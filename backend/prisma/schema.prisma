// Prisma schema — RumaCart (Fase 1 core models)
// Dokumentasi lengkap: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== ENUMS ==================

enum Role {
  SUPER_ADMIN
  ADMIN
  ADMIN_POINT // "Admin Lokasi" — kelola 1 lokasi (RDH/Mart/Point) tertentu, terkunci ke managedPointId
  KASIR
  GUDANG
  KURIR
  CUSTOMER
}

// Jaringan distribusi RumaCart (Hub and Spoke):
// RDH   = RumaCart Distribution Hub, gudang utama 1 per kota, satu-satunya
//         yang boleh terima Purchase Order langsung dari supplier.
// MART  = RumaCart Mart, outlet retail skala besar, disuplai dari RDH kotanya.
// POINT = RumaCart Point, pickup point/last-mile kecil, disuplai dari RDH/Mart.
enum LocationType {
  RDH
  MART
  POINT
}

enum OrderStatus {
  PENDING       // Menunggu diproses
  PROCESSED     // Diproses
  PREPARED      // Disiapkan (picking/packing di gudang)
  PICKED_UP     // Diambil gudang / siap kirim
  SHIPPED       // Dikirim
  COMPLETED     // Selesai
  CANCELLED     // Dibatalkan
}

enum ShippingMethod {
  PICKUP // ambil sendiri di Point, selalu gratis & selalu tersedia
  DELIVERY // diantar kurir — biaya & ketersediaan tergantung DeliveryArea Point tujuan
}

enum PaymentMethod {
  COD
  TRANSFER
  EWALLET
}

enum PaymentStatus {
  PENDING
  AWAITING_VERIFICATION // customer klaim sudah transfer, menunggu dicek manual oleh Admin/Kasir
  PAID
  FAILED
}

enum InventoryMoveType {
  STOCK_IN
  STOCK_OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  SALE
  RETURN   // barang kembali dari customer/lokasi lain, stok bertambah
  DAMAGE   // barang rusak, stok berkurang & tidak bisa dijual lagi
  EXPIRED  // barang kadaluarsa, stok berkurang & tidak bisa dijual lagi
}

enum RestockRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED // sudah dibuatkan Stock Transfer dari lokasi sumber
}

enum CashflowType {
  IN
  OUT
}

// 3 kantong cashflow (Pocket Cashflow / Profit First):
// INVESTASI  = modal pemilik/investor, saldonya ditampilkan sebagai "Outstanding" (minus)
// INVENTARIS = dana harga modal barang terjual, dipakai buat belanja stok/supplier
// PROFIT     = keuntungan bersih, dipakai buat pengembangan usaha/bonus/dividen/dst
enum CashflowPocket {
  INVESTASI
  INVENTARIS
  PROFIT
}

enum PurchaseOrderStatus {
  DRAFT      // masih disusun, belum dikirim ke supplier
  ORDERED    // sudah dipesan ke supplier, menunggu barang datang
  RECEIVED   // barang sudah diterima, stok & cashflow sudah tercatat
  CANCELLED  // dibatalkan
}

enum VoucherDiscountType {
  FLAT     // potongan nominal tetap (Rupiah)
  PERCENT  // potongan persentase dari subtotal, bisa dibatasi maxDiscount
}

enum NotificationType {
  ORDER   // perubahan status pesanan / pembayaran
  PROMO   // voucher/promo baru
  SYSTEM  // pengumuman umum
}

enum StockTransferStatus {
  SENT      // dikirim dari Pusat, dalam perjalanan ke Point
  RECEIVED  // sudah dikonfirmasi diterima Point, stok sudah masuk
  CANCELLED
}

// ================== USER & AUTH ==================

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  phone          String?
  image          String? // URL avatar (Cloudinary) — dipakai customer, opsional
  role           Role     @default(CUSTOMER)
  managedPointId String?  // hanya diisi untuk role ADMIN_POINT — Point yang dikelola
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  managedPoint     FulfillmentPoint?  @relation("PointAdmin", fields: [managedPointId], references: [id])
  addresses        Address[]
  ordersAsCustomer Order[]            @relation("CustomerOrders")
  ordersAsCourier  Order[]            @relation("CourierOrders")
  inventoryMoves   InventoryHistory[]
  cashflowEntries  Cashflow[]
  wishlist         Wishlist[]
  reviews          Review[]
  purchaseOrders   PurchaseOrder[]
  notifications    Notification[]
  stockTransfers   StockTransfer[]

  @@map("users")
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  label         String   // "Rumah", "Kos", dst
  recipientName String
  phone         String
  fullAddress   String
  kecamatan     String? // dipakai cocokkan jangkauan pengiriman (DeliveryArea) tiap Point
  city          String
  province      String
  postalCode    String?
  latitude      Float?
  longitude     Float?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ================== CATALOG ==================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products Product[]

  @@map("categories")
}

// Product = "induk" produk (nama, kategori, brand, kata kunci pencarian, foto
// default) — TIDAK punya SKU/barcode/harga/stok sendiri lagi sejak varian
// diperkenalkan. 1 Product WAJIB punya minimal 1 ProductVariant (kalau produk
// tidak punya varian sungguhan, tetap dibuatkan 1 varian "default" — supaya
// SEMUA unit yang benar-benar dijual/di-stok selalu lewat ProductVariant,
// tidak ada 2 cara berbeda untuk hal yang sama).
model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  categoryId    String
  brand         String?
  searchKeywords String? // kata kunci tambahan (dipisah koma) biar gampang ditemukan pencarian, contoh "mie instan pedas rendang"
  minStock      Int      @default(5) // nilai default dipakai saat bikin ProductVariant baru
  images        String[] @default([])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  wishlist Wishlist[]
  reviews  Review[]

  @@map("products")
}

// ProductVariant = unit yang BENAR-BENAR dijual & di-stok (contoh: "Original",
// "Pedas Level 3", "Karton isi 40"). SKU/barcode/berat/dimensi/harga/stok
// semuanya di level ini, BUKAN di Product — karena tiap varian bisa beda
// fisik & beda harga meskipun "produk"-nya sama.
model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String   // nama varian, contoh: "Original", "Pedas", "85g", "Karton isi 40"
  sku        String   @unique
  barcode    String?  @unique
  weightGram Int      @default(0)
  lengthCm   Float?   // dimensi paket, dipakai estimasi ongkir/packing
  widthCm    Float?
  heightCm   Float?
  minStock   Int      @default(5)
  image      String?  // opsional — override foto default Product kalau varian ini beda tampilan
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product             @relation(fields: [productId], references: [id])
  inventory  Inventory[]
  orderItems OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockTransferItems StockTransferItem[]
  restockRequests    RestockRequest[]

  @@map("product_variants")
}

// ================== WISHLIST & REVIEW ==================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // 1 produk cuma bisa di-wishlist sekali oleh user yang sama
  @@map("wishlists")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // 1 user cuma bisa review 1 produk sekali (bisa di-edit, bukan dobel)
  @@map("reviews")
}

// ================== FULFILLMENT POINT & INVENTORY ==================

model FulfillmentPoint {
  id        String       @id @default(cuid())
  name      String       // "RumaCart Point A - Bandung Timur"
  code      String       @unique // "PNT-A"
  type      LocationType @default(POINT) // RDH / MART / POINT — lihat enum LocationType
  address   String
  city      String
  latitude  Float
  longitude Float
  phone     String?
  serviceRadiusKm Float?  // radius layanan (km), dipakai nanti utk Smart Order Routing
  operatingHours  String? // teks bebas, misal "08:00 - 21:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Hierarki Hub and Spoke: Mart/Point disuplai oleh 1 RDH induk di kotanya.
  // RDH sendiri tidak punya induk (parentHubId null).
  parentHubId String?
  parentHub   FulfillmentPoint?  @relation("HubSpokes", fields: [parentHubId], references: [id])
  spokes      FulfillmentPoint[] @relation("HubSpokes")

  inventory Inventory[]
  orders    Order[]
  cashflow  Cashflow[]
  purchaseOrders PurchaseOrder[]
  admins         User[]           @relation("PointAdmin")
  localSuppliers Supplier[]
  stockTransfers      StockTransfer[]   @relation("TransferTo")
  stockTransfersFrom  StockTransfer[]   @relation("TransferFrom")
  restockRequests     RestockRequest[]  @relation("RestockPoint")
  restockRequestsSourced RestockRequest[] @relation("RestockSource")
  deliveryAreas       DeliveryArea[]

  @@map("fulfillment_points")
}

// Area jangkauan kurir 1 Point, per kecamatan — dipakai buat tentuin apakah
// Point ini bisa DELIVERY ke alamat tertentu, dan berapa biayanya. Kecamatan
// yang tidak terdaftar di sini artinya Point tersebut tidak melayani
// pengiriman ke situ (customer tetap bisa PICKUP langsung ke Point).
model DeliveryArea {
  id        String   @id @default(cuid())
  pointId   String
  kecamatan String
  city      String
  cost      Int // biaya antar ke kecamatan ini dari Point ini
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  point FulfillmentPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@unique([pointId, kecamatan, city])
  @@map("delivery_areas")
}

model Inventory {
  id        String   @id @default(cuid())
  variantId String
  pointId   String
  stock     Int      @default(0)
  minStock  Int      @default(5)
  maxStock    Int?   // batas atas stok "ideal" di lokasi ini — dipakai hitung jumlah Restock Request
  safetyStock Int?   // cadangan minimum yang tidak boleh disentuh kecuali darurat (opsional, buat referensi Admin)

  // ====== HARGA (per lokasi, bukan lagi 1 harga global di Product) ======
  // basePrice: "Harga Dasar" — CUMA diisi & diubah oleh Admin Lokasi RDH.
  //   Buat Mart/Point, nilai ini disalin dari basePrice RDH induk pas klaim
  //   (snapshot), dipakai sebagai acuan modal/referensi "jual di bawah harga dasar".
  // sellPrice/discountPrice: harga jual ke customer — CUMA diisi & diubah oleh
  //   Admin Lokasi Mart/Point (tidak relevan buat RDH, karena RDH tidak jual
  //   langsung ke customer).
  basePrice     Int?
  sellPrice     Int?
  discountPrice Int?

  updatedAt DateTime @updatedAt

  variant ProductVariant   @relation(fields: [variantId], references: [id])
  point   FulfillmentPoint @relation(fields: [pointId], references: [id])
  history InventoryHistory[]

  @@unique([variantId, pointId])
  @@map("inventory")
}

model InventoryHistory {
  id          String             @id @default(cuid())
  inventoryId String
  type        InventoryMoveType
  qty         Int                // selalu positif, arah ditentukan oleh `type`
  note        String?
  refId       String?            // id order / PO / transfer terkait
  createdById String?
  createdAt   DateTime           @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@map("inventory_history")
}

// ================== VOUCHER (sederhana) ==================

model Voucher {
  id             String              @id @default(cuid())
  code           String              @unique
  description    String?
  discountType   VoucherDiscountType @default(FLAT)
  discountAmount Int                 // FLAT: potongan Rupiah. PERCENT: persen (1-100)
  maxDiscount    Int?                // batas maksimal potongan untuk tipe PERCENT (opsional)
  minPurchase    Int                 @default(0)
  quota          Int                 @default(100)
  used           Int                 @default(0)
  isActive       Boolean             @default(true)
  expiresAt      DateTime?
  createdAt      DateTime            @default(now())

  orders Order[]

  @@map("vouchers")
}

// ================== ORDER ==================

model Order {
  id             String         @id @default(cuid())
  orderNumber    String         @unique
  customerId     String
  pointId        String
  addressId      String?
  courierId      String?
  voucherId      String?
  status         OrderStatus    @default(PENDING)
  shippingMethod ShippingMethod @default(PICKUP)
  paymentMethod  PaymentMethod  @default(COD)
  subtotal       Int
  shippingCost   Int            @default(0)
  discount       Int            @default(0)
  total          Int
  costTotal      Int            @default(0) // total harga modal (costPrice x qty) untuk order ini
  belowCost      Boolean        @default(false) // true kalau (subtotal - discount) < costTotal, artinya diskon menggerus modal
  isBackOrder    Boolean        @default(false) // true kalau tidak ada Point/Mart terdekat yang stoknya cukup, jadi dipenuhi langsung dari RDH (estimasi lebih lama)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer User             @relation("CustomerOrders", fields: [customerId], references: [id])
  courier  User?            @relation("CourierOrders", fields: [courierId], references: [id])
  point    FulfillmentPoint @relation(fields: [pointId], references: [id])
  address  Address?         @relation(fields: [addressId], references: [id])
  voucher  Voucher?         @relation(fields: [voucherId], references: [id])
  items    OrderItem[]
  payment  Payment?
  statusHistory OrderStatusHistory[]

  @@map("orders")
}

// Riwayat perpindahan status order, dicatat otomatis tiap kali status berubah.
// Dipakai buat tampilkan timeline pelacakan pesanan ke customer (kapan diproses,
// disiapkan, diambil kurir, dikirim, selesai) — fokus di titik Point & waktu,
// bukan lacak GPS kurir secara live.
model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String
  qty       Int
  price     Int    // harga satuan saat order dibuat (snapshot)
  subtotal  Int

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  method    PaymentMethod
  amount    Int
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ================== CASHFLOW ==================

model Cashflow {
  id            String       @id @default(cuid())
  type          CashflowType
  category      String       // "Penjualan", "Belanja Supplier", "Setor Modal", dst
  amount        Int
  costAmount    Int?         // untuk entry Penjualan: porsi yang menutup modal (harga dasar produk) -> masuk Kantong Inventaris
  profitAmount  Int?         // untuk entry Penjualan: porsi keuntungan bersih (bisa negatif kalau rugi karena diskon) -> masuk Kantong Profit
  // Kantong tujuan transaksi ini (dipakai untuk entry NON-penjualan: setor modal,
  // belanja supplier, bonus karyawan, dst). Entry Penjualan tidak perlu diisi ini
  // karena otomatis kebagi 2 kantong sekaligus lewat costAmount & profitAmount.
  pocket        CashflowPocket?
  description   String?
  pointId       String?
  refType       String?      // "ORDER", "EXPENSE", dst
  refId         String?
  createdById   String?
  createdAt     DateTime     @default(now())

  point     FulfillmentPoint? @relation(fields: [pointId], references: [id])
  createdBy User?             @relation(fields: [createdById], references: [id])

  @@map("cashflow")
}

// ================== SUPPLIER & PURCHASE ORDER ==================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  pointId     String?  // null = supplier Pusat (bisa dipakai semua Point). Diisi = supplier lokal, cuma dipakai Point itu.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  point          FulfillmentPoint? @relation(fields: [pointId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  poNumber    String              @unique
  supplierId  String
  pointId     String              // Point tujuan penerimaan barang
  status      PurchaseOrderStatus @default(ORDERED)
  totalAmount Int                 @default(0)
  notes       String?
  createdById String?
  createdAt   DateTime            @default(now())
  receivedAt  DateTime?

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  point     FulfillmentPoint    @relation(fields: [pointId], references: [id])
  createdBy User?               @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id        String @id @default(cuid())
  poId      String
  variantId String
  qty       Int
  costPrice Int    // harga beli satuan saat PO dibuat (snapshot)
  subtotal  Int

  po      PurchaseOrder  @relation(fields: [poId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
}

// ================== TRANSFER STOK (ANTAR LOKASI) ==================
// Sesuai arsitektur Hub and Spoke: transfer bisa RDH->Mart, RDH->Point,
// Mart->Point, Mart->Mart, RDH->RDH, dst — beda dari PurchaseOrder (beli dari
// Supplier eksternal), transfer ini tidak melibatkan uang, cuma pemindahan
// stok antar lokasi RumaCart sendiri. `fromPointId` nullable buat data lama
// (dulu implisit "dari Pusat", stok sumbernya tidak dipotong).

model StockTransfer {
  id             String              @id @default(cuid())
  transferNumber String              @unique
  fromPointId    String?             // null = data lama ("dari Pusat", stok sumber tidak dipotong)
  toPointId      String
  status         StockTransferStatus @default(SENT)
  notes          String?
  createdById    String?
  createdAt      DateTime            @default(now())
  receivedAt     DateTime?

  fromPoint FulfillmentPoint?   @relation("TransferFrom", fields: [fromPointId], references: [id])
  toPoint   FulfillmentPoint    @relation("TransferTo", fields: [toPointId], references: [id])
  createdBy User?               @relation(fields: [createdById], references: [id])
  items     StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id         String @id @default(cuid())
  transferId String
  variantId  String
  qty        Int

  transfer StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@map("stock_transfer_items")
}

// ================== SMART RESTOCK ==================
// Dibuat otomatis oleh sistem begitu stok 1 produk di 1 lokasi turun sampai
// atau di bawah minStock (dipicu setelah penjualan/stock-out/transfer keluar).
// Bisa juga dibuat manual oleh Admin Lokasi. Setelah di-approve & di-"fulfill",
// sistem otomatis bikin Stock Transfer dari lokasi sumber ke lokasi peminta.
model RestockRequest {
  id            String                @id @default(cuid())
  requestNumber String                @unique
  pointId       String                // lokasi yang butuh restock
  variantId     String
  qty           Int                   // jumlah yang diminta
  status        RestockRequestStatus  @default(PENDING)
  sourceHubId   String?               // lokasi yang akan mensuplai (biasanya RDH/Mart induk)
  isAuto        Boolean               @default(false) // true kalau dibuat otomatis oleh sistem
  note          String?
  transferId    String?               // diisi setelah di-fulfill, link ke Stock Transfer yang dibuat
  createdAt     DateTime              @default(now())
  approvedAt    DateTime?
  fulfilledAt   DateTime?

  point     FulfillmentPoint  @relation("RestockPoint", fields: [pointId], references: [id])
  sourceHub FulfillmentPoint? @relation("RestockSource", fields: [sourceHubId], references: [id])
  variant   ProductVariant    @relation(fields: [variantId], references: [id])

  @@map("restock_requests")
}

// ================== NOTIFIKASI ==================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String
  refId     String?          // id order / voucher terkait, untuk link saat diklik
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
